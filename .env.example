# Samples Configuration
# Base URL for loading sample files
VITE_SAMPLES_BASE_URL=/samples/

# Path to strudel.json file (relative to base URL)
VITE_STRUDEL_JSON_PATH=strudel.json

# Use minimal samples for faster loading (true/false)
VITE_USE_MINIMAL_SAMPLES=false

# Fallback to basic samples if strudel.json fails to load (true/false)
VITE_FALLBACK_TO_BASIC_SAMPLES=true

# Cache loaded samples in memory (true/false)
VITE_CACHE_SAMPLES=true

# Lazy load samples on demand (true/false)
VITE_LAZY_LOAD_SAMPLES=true

# Example: Load from external server
# VITE_SAMPLES_BASE_URL=https://my-sample-server.com/samples/

# Example: Use minimal samples for production
# VITE_USE_MINIMAL_SAMPLES=true